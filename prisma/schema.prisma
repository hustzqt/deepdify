// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql" // 修复：从 sqlite 改为 postgresql
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // 添加：Neon 需要
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  name     String?
  password String
  role     String  @default("USER")

  emailVerified DateTime?
  image         String? // NextAuth default avatar field

  // Day 3 安全字段
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  passwordResetCreated DateTime?

  // Day 4 Profile
  company   String? @db.VarChar(100)
  phone     String? @db.VarChar(50)
  timezone  String  @default("Asia/Shanghai") @db.VarChar(50)
  language  String  @default("zh") @db.VarChar(10)
  bio       String? @db.VarChar(500)

  // 关系字段（修复：添加反向引用）
  brands   Brand[]
  accounts Account[]
  sessions Session[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([passwordResetToken])
  @@index([email])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Brand 品牌模型
model Brand {
  id          String   @id @default(cuid())
  name        String   // 品牌名称
  description String?  // 品牌描述
  industry    String   // 行业类别（fashion/electronics/home/etc）
  tone        String   @default("professional") // 语调：professional/friendly/luxury/playful
  targetAudience String? // 目标受众描述

  // 视觉风格
  colorPrimary   String? // 主色
  colorSecondary String? // 辅色
  fontHeading    String? // 标题字体偏好
  fontBody       String? // 正文字体偏好

  // 内容规范
  contentGuidelines String? @db.Text // 内容规范 JSON
  keywords          String[] // 品牌关键词

  // Dify 集成
  difyKnowledgeId   String?  // Dify 知识库 ID（上传文档后生成）
  difyDatasetId     String?  // Dify Dataset ID

  // 关联
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("brands")
}
