# Dify CE docker-compose 环境变量片段
# 部署时：在官方 Dify 安装目录打开 .env，将下列项替换/合并进去（避免与本仓库 Next.js :3000 冲突）

# 将默认端口从 80/443 改为 3001（避免与 deepdify:3000 冲突）
NGINX_PORT=3001
NGINX_HTTPS_PORT=3443

# 保持内部 PostgreSQL/Redis，但暴露端口改为非标准，或直接不暴露（推荐）
# 找到并修改：
DB_PORT=5433
# 原为 5432，避开本机/其他容器的 PostgreSQL

REDIS_PORT=6380
# 原为 6379

# 可选：启用中文界面
DEFAULT_LANGUAGE=zh-Hans
