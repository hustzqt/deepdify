// src/lib/email/reset-password.ts
// 数据库版密码重置 - 支持即时撤销和审计

import { hash } from 'bcrypt'
import { prisma } from '@/lib/prisma'
import crypto from 'node:crypto'

const RESET_TOKEN_BYTES = 32
const RESET_TOKEN_TTL_MS = 15 * 60 * 1000  // 15分钟有效期
const MIN_REQUEST_INTERVAL_MS = 5 * 60 * 1000  // 5分钟内禁止重复请求

/**
 * 生成密码重置令牌并保存到数据库
 * 返回复合令牌格式：userId:tokenString
 */
export async function generatePasswordResetToken(email: string): Promise<string | null> {
  const user = await prisma.user.findUnique({ 
    where: { email },
    select: { 
      id: true, 
      email: true, 
      passwordResetCreated: true,
      name: true 
    }
  })
  
  // 安全：即使用户不存在也返回 null，防止邮箱枚举
  if (!user) {
    console.log(`[Password Reset] Request for non-existent email: ${email}`)
    return null
  }

  // 频率限制检查
  if (user.passwordResetCreated) {
    const timeSinceLastRequest = Date.now() - user.passwordResetCreated.getTime()
    if (timeSinceLastRequest < MIN_REQUEST_INTERVAL_MS) {
      throw new Error('TOO_FREQUENT_REQUESTS')
    }
  }

  // 生成加密安全的随机令牌
  const tokenString = crypto.randomBytes(RESET_TOKEN_BYTES).toString('hex')
  const expiresAt = new Date(Date.now() + RESET_TOKEN_TTL_MS)

  // 原子更新：新令牌覆盖旧令牌（实现单设备有效）
  await prisma.user.update({
    where: { id: user.id },
    data: {
      passwordResetToken: tokenString,
      passwordResetExpires: expiresAt,
      passwordResetCreated: new Date(),
    },
  })

  console.log(`[Password Reset] Token generated for user: ${user.email}`)
  
  // 返回复合令牌（包含 userId 以便查询）
  return `${user.id}:${tokenString}`
}

/**
 * 验证令牌有效性（查数据库）
 */
export async function verifyPasswordResetToken(
  compositeToken: string
): Promise<{ userId: string; email: string }> {
  const [userId, tokenString] = compositeToken.split(':')

  if (!userId || !tokenString || tokenString.length !== RESET_TOKEN_BYTES * 2) {
    throw new Error('INVALID_TOKEN_FORMAT')
  }

  const user = await prisma.user.findFirst({
    where: {
      id: userId,
      passwordResetToken: tokenString,
      passwordResetExpires: { gt: new Date() }, // 未过期
    },
    select: { id: true, email: true }
  })

  if (!user) {
    throw new Error('INVALID_OR_EXPIRED_TOKEN')
  }

  return { userId: user.id, email: user.email }
}

/**
 * 重置密码并清除令牌（一次性使用）
 */
export async function resetPasswordWithToken(
  compositeToken: string,
  newPassword: string
): Promise<void> {
  const { userId } = await verifyPasswordResetToken(compositeToken)

  const hashedPassword = await hash(newPassword, 10)

  // 事务：更新密码 + 清除令牌
  await prisma.user.update({
    where: { id: userId },
    data: {
      password: hashedPassword,
      passwordResetToken: null,
      passwordResetExpires: null,
      passwordResetCreated: null,
    },
  })

  console.log(`[Password Reset] Password updated for user: ${userId}`)
}

/**
 * 撤销所有待处理的重置请求（管理员用或用户修改密码后）
 */
export async function revokeAllPasswordResetTokens(userId: string): Promise<void> {
  await prisma.user.update({
    where: { id: userId },
    data: {
      passwordResetToken: null,
      passwordResetExpires: null,
      passwordResetCreated: null,
    },
  })
  console.log(`[Password Reset] All tokens revoked for user: ${userId}`)
}

/**
 * Mock 邮件发送（开发环境）
 * 生产环境替换为真实 SMTP 服务
 */
export function sendPasswordResetEmail(to: string, resetLink: string): void {
  console.log('\n' + '='.repeat(60))
  console.log('[MOCK EMAIL] Password Reset Request')
  console.log('='.repeat(60))
  console.log(`To: ${to}`)
  console.log(`Subject: 重置您的 Deepdify 密码`)
  console.log(`Link: ${resetLink}`)
  console.log('='.repeat(60) + '\n')
  
