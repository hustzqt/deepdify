# ========================================
# Deepdify Studio — environment template
# Copy to .env.local and fill real values (never commit .env.local)
# ========================================

# --- Database (PostgreSQL; Neon / Supabase / local) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# --- NextAuth v5 / Auth.js ---
# Use either AUTH_SECRET (preferred) or NEXTAUTH_SECRET (both supported in code).
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET=""
NEXTAUTH_SECRET=""

# --- Dev server port (optional; avoids random port when 3000 is busy) ---
PORT=3000

# --- Public app (optional) ---
NEXT_PUBLIC_APP_NAME="Deepdify Studio"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Supabase (optional; if used for storage) ---
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# --- AI: Dify (server-side only) ---
DIFY_BASE_URL="https://api.dify.ai/v1"
DIFY_BRAND_ANALYSIS_KEY=""
# Optional fallback name used by some routes:
DIFY_API_KEY=""

# --- AI: OpenAI-compatible (optional; DeepSeek / OpenAI) ---
OPENAI_API_KEY=""
