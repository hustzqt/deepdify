# =============================================================================
# Deepdify Studio — environment template
# Copy to `.env.local` and fill real values. Never commit `.env.local`.
# =============================================================================
#
# Legend:
#   [PROD]  Required for a secure production deployment
#   [DEV]   Optional for local development (some features stubbed if missing)
#   [FEAT]  Only if you use that integration (e.g. Supabase helpers)
#

# ---------------------------------------------------------------------------
# Database (Neon PostgreSQL) — [PROD]
# ---------------------------------------------------------------------------
# Pooled URL (serverless / Vercel-friendly)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.neon.tech/neondb?sslmode=require"
# Direct URL for Prisma migrations (Neon dashboard often shows both)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.neon.tech/neondb?sslmode=require"

# ---------------------------------------------------------------------------
# Auth (NextAuth v5 / Auth.js) — [PROD]
# ---------------------------------------------------------------------------
# Public origin of the app (no trailing slash). Must match the deployed URL.
NEXTAUTH_URL="http://localhost:3000"
# Secret for JWT / cookies (min ~32 chars). Use one of:
AUTH_SECRET="replace-with-openssl-rand-base64-32"
# NEXTAUTH_SECRET="legacy-alias-still-supported"

# ---------------------------------------------------------------------------
# Dify (brand analysis workflow) — [PROD] for /api/ai/brand-analyze
# ---------------------------------------------------------------------------
DIFY_BASE_URL="https://api.dify.ai/v1"
DIFY_BRAND_ANALYSIS_KEY="app-xxxxx"
# Optional alias read by the same route:
# DIFY_API_KEY="app-xxxxx"

# ---------------------------------------------------------------------------
# Redis rate limiting — [PROD] recommended (pick ONE strategy)
# ---------------------------------------------------------------------------
# A) Upstash REST (recommended on Vercel / serverless)
# UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxxx"
#
# B) TCP Redis (Docker / self-hosted)
# REDIS_URL="redis://127.0.0.1:6379"
#
# If neither A nor B is set, the API falls back to in-memory limits (dev-only).

# ---------------------------------------------------------------------------
# Public app — [DEV] / [PROD] for links in emails etc.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Deepdify Studio"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Supabase — [FEAT] optional (some client helpers expect these)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=""
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------
# PORT=3000
